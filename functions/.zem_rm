# Remove profile

.zem_rm() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local profile=$1
    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local profile_file="$profile_dir/$profile"

    [[ $1 == (-h|--help|help) ]] && { .zem_help rm; return $? }

    # Validate arguments
    if [[ -z $profile ]]; then
        echo "${ZEM_MSGS[common_missing_profile]}"
        echo "${ZEM_MSGS[rm_usage]}"
        return 1
    fi

    # Check if profile exists
    if [[ ! -f $profile_file ]]; then
        printf "${ZEM_MSGS[common_not_exist]}\n" "$profile"
        echo "${ZEM_MSGS[rm_list_hint]}"
        return 1
    fi

    # Confirm deletion
    printf "${ZEM_MSGS[rm_confirm]}\n" "$profile"
    local prompt="${ZEM_MSGS[rm_confirm_hint]}"
    read "?${prompt}" response

    if [[ ! $response =~ ^[yY]$ ]]; then
        echo "${ZEM_MSGS[common_cancelled]}"
        return 0
    fi

    # Delete the profile
    rm -f "$profile_file" || {
        printf "${ZEM_MSGS[rm_failed]}\n" "$profile"
        return 1
    }

    printf "${ZEM_MSGS[rm_success]}\n" "$profile"
    return 0
}
