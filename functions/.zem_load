# Load profile(s) into current session

.zem_load() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local set_default=0
    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local -a profiles loaded_profiles current_list
    local failed=0

    [[ $1 == (-h|--help|help) ]] && { .zem_help load; return $? }

    # Parse current loaded profiles once before the loop
    current_list=(${(s: :)ZEM_LOADED_PROFILES})

    # Parse arguments: --default flag can appear anywhere
    local arg
    for arg in "$@"; do
        if [[ $arg == "--default" ]]; then
            set_default=1
        else
            profiles+=("$arg")
        fi
    done

    # Validate: at least one profile required
    if (( ${#profiles} == 0 )); then
        echo "${ZEM_MSGS[common_missing_profile]}"
        echo "${ZEM_MSGS[load_usage]}"
        return 1
    fi

    # Load each profile
    local profile profile_file
    for profile in "${profiles[@]}"; do
        profile_file="$profile_dir/$profile"

        # Validate profile name
        if ! .zem_validate_profile_name "$profile"; then
            failed=1
            continue
        fi

        # Check if profile exists
        if [[ ! -f $profile_file ]]; then
            printf "${ZEM_MSGS[common_not_exist]}\n" "$profile"
            echo "${ZEM_MSGS[common_list_hint]}"
            failed=1
            continue
        fi

        # Optional: Confirm before loading (controlled by ZEM_CONFIRM_LOAD)
        if [[ -n $ZEM_CONFIRM_LOAD ]]; then
            printf "${ZEM_MSGS[load_warn_exec]}\n" "$profile"
            printf "${ZEM_MSGS[load_warn_file]}\n" "$profile_file"
            local prompt="${ZEM_MSGS[load_confirm]}"
            read "?${prompt}" response
            if [[ ! $response =~ ^[yY]$ ]]; then
                echo "${ZEM_MSGS[common_cancelled]}"
                continue
            fi
        fi

        # Source the profile
        if source "$profile_file"; then
            printf "${ZEM_MSGS[load_success]}\n" "$profile"
            loaded_profiles+=("$profile")
            # Track in current_list (avoid duplicates)
            if (( current_list[(Ie)$profile] == 0 )); then
                current_list+=("$profile")
            fi
        else
            printf "${ZEM_MSGS[load_failed]}\n" "$profile"
            failed=1
        fi
    done

    # Write back ZEM_LOADED_PROFILES once after all loads
    export ZEM_LOADED_PROFILES="${current_list[*]}"

    # Set as default if requested (only successfully loaded profiles)
    if (( set_default )) && (( ${#loaded_profiles} > 0 )); then
        .zem_config_set default_profile "${loaded_profiles[*]}" || {
            echo "${ZEM_MSGS[load_failed_default]}"
            return 1
        }
        if (( ${#loaded_profiles} == 1 )); then
            printf "${ZEM_MSGS[load_set_default_single]}\n" "${loaded_profiles[1]}"
        else
            printf "${ZEM_MSGS[load_set_default_multi]}\n" "${loaded_profiles[*]}"
        fi
    fi

    return $failed
}
