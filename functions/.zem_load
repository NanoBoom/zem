# Load profile(s) into current session

.zem_load() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local set_default=0
    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local -a profiles loaded_profiles
    local failed=0

    # Parse arguments: --default flag can appear anywhere
    local arg
    for arg in "$@"; do
        if [[ $arg == "--default" ]]; then
            set_default=1
        else
            profiles+=("$arg")
        fi
    done

    # Validate: at least one profile required
    if (( ${#profiles} == 0 )); then
        echo "❌ Missing profile name."
        echo "Usage: zem load <profile> [<profile2> ...] [--default]"
        return 1
    fi

    # Load each profile
    local profile profile_file
    for profile in "${profiles[@]}"; do
        profile_file="$profile_dir/$profile"

        # Validate profile name
        if ! .zem_validate_profile_name "$profile"; then
            failed=1
            continue
        fi

        # Check if profile exists
        if [[ ! -f $profile_file ]]; then
            echo "❌ Profile '$profile' does not exist."
            echo "   Run 'zem list' to see available profiles."
            failed=1
            continue
        fi

        # Optional: Confirm before loading (controlled by ZEM_CONFIRM_LOAD)
        if [[ -n $ZEM_CONFIRM_LOAD ]]; then
            echo "⚠️  Warning: This will execute code from '$profile'"
            echo "   File: $profile_file"
            read "?Continue? [y/N] " response
            if [[ ! $response =~ ^[yY]$ ]]; then
                echo "Cancelled."
                continue
            fi
        fi

        # Source the profile
        if source "$profile_file"; then
            echo "🚀 Profile '$profile' loaded successfully!"
            loaded_profiles+=("$profile")
        else
            echo "❌ Failed to load profile: $profile"
            failed=1
        fi
    done

    # Set as default if requested (only successfully loaded profiles)
    if (( set_default )) && (( ${#loaded_profiles} > 0 )); then
        .zem_config_set default_profile "${loaded_profiles[*]}" || {
            echo "❌ Failed to save default profile(s)."
            return 1
        }
        if (( ${#loaded_profiles} == 1 )); then
            echo "✅ Set '${loaded_profiles[1]}' as default profile."
        else
            echo "✅ Set '${loaded_profiles[*]}' as default profiles."
        fi
    fi

    return $failed
}
