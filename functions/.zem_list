# List all profiles

.zem_list() {
    emulate -L zsh
    setopt extended_glob

    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"

    [[ $1 == (-h|--help|help) ]] && { .zem_help list; return $? }

    # Check if profile directory exists
    if [[ ! -d $profile_dir ]]; then
        echo "${ZEM_MSGS[list_empty]}"
        echo "${ZEM_MSGS[list_empty_hint]}"
        return 0
    fi

    # Get list of profiles (N flag returns empty array if no matches)
    local -a profiles
    profiles=( "$profile_dir"/*(N:t) )

    # Check if any profiles exist
    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo "${ZEM_MSGS[list_empty]}"
        echo "${ZEM_MSGS[list_empty_hint]}"
        return 0
    fi

    echo "${ZEM_MSGS[list_header]}"
    for profile in "${profiles[@]}"; do
        [[ -z $profile ]] && continue
        echo "  • $profile"
    done

    return 0
}
