# Manage default profile(s)

.zem_default() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local -a profiles

    [[ $1 == (-h|--help|help) ]] && { .zem_help default; return $? }

    # Handle --unset flag
    if [[ $1 == "--unset" ]]; then
        .zem_config_set default_profile "" || {
            echo "${ZEM_MSGS[default_unset_failed]}"
            return 1
        }
        echo "${ZEM_MSGS[default_unset_success]}"
        echo "${ZEM_MSGS[default_unset_hint]}"
        return 0
    fi

    # If no argument, show current default(s)
    if (( $# == 0 )); then
        local current=$(.zem_config_get default_profile)
        if [[ -z $current ]]; then
            echo "${ZEM_MSGS[default_none]}"
            echo "${ZEM_MSGS[default_usage]}"
        else
            printf "${ZEM_MSGS[default_current]}\n" "$current"
            local p
            for p in ${(s: :)current}; do
                if [[ ! -f $profile_dir/$p ]]; then
                    printf "${ZEM_MSGS[default_warn_missing]}\n" "$p"
                fi
            done
        fi
        return 0
    fi

    profiles=("$@")

    # Validate each profile exists
    local profile
    for profile in "${profiles[@]}"; do
        .zem_validate_profile_name "$profile" || return 1
        if [[ ! -f $profile_dir/$profile ]]; then
            printf "${ZEM_MSGS[common_not_exist]}\n" "$profile"
            echo "${ZEM_MSGS[common_list_hint]}"
            return 1
        fi
    done

    # Set default profile(s)
    .zem_config_set default_profile "${profiles[*]}" || {
        echo "${ZEM_MSGS[default_set_failed]}"
        return 1
    }

    if (( ${#profiles} == 1 )); then
        printf "${ZEM_MSGS[default_set_single]}\n" "${profiles[1]}"
        echo "${ZEM_MSGS[default_set_hint_single]}"
    else
        printf "${ZEM_MSGS[default_set_multi]}\n" "${profiles[*]}"
        echo "${ZEM_MSGS[default_set_hint_multi]}"
    fi
    return 0
}
