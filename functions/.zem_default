# Manage default profile(s)

.zem_default() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local -a profiles

    # Handle --unset flag
    if [[ $1 == "--unset" ]]; then
        .zem_config_set default_profile "" || {
            echo "❌ Failed to unset default profile."
            return 1
        }
        echo "✅ Default profile unset."
        echo "   New shells will not auto-load any profile."
        return 0
    fi

    # If no argument, show current default(s)
    if (( $# == 0 )); then
        local current=$(.zem_config_get default_profile)
        if [[ -z $current ]]; then
            echo "📂 No default profile set."
            echo "Usage: zem default <profile> [<profile2> ...]"
        else
            echo "📌 Default profile(s): $current"
            local p
            for p in ${(s: :)current}; do
                if [[ ! -f $profile_dir/$p ]]; then
                    echo "⚠️  Warning: Profile '$p' does not exist."
                fi
            done
        fi
        return 0
    fi

    profiles=("$@")

    # Validate each profile exists
    local profile
    for profile in "${profiles[@]}"; do
        .zem_validate_profile_name "$profile" || return 1
        if [[ ! -f $profile_dir/$profile ]]; then
            echo "❌ Profile '$profile' does not exist."
            echo "Run 'zem list' to see available profiles."
            return 1
        fi
    done

    # Set default profile(s)
    .zem_config_set default_profile "${profiles[*]}" || {
        echo "❌ Failed to set default profile."
        return 1
    }

    if (( ${#profiles} == 1 )); then
        echo "✅ Default profile set to '${profiles[1]}'"
        echo "   New shells will automatically load this profile."
    else
        echo "✅ Default profiles set to '${profiles[*]}'"
        echo "   New shells will automatically load these profiles."
    fi
    return 0
}
