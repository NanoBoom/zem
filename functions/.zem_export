# Export profile to file

.zem_export() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local profile=$1
    local output_file=$2
    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local profile_file="$profile_dir/$profile"

    [[ $1 == (-h|--help|help) ]] && { .zem_help export; return $? }

    # Validate arguments
    if [[ -z $profile ]]; then
        echo "${ZEM_MSGS[common_missing_profile]}"
        echo "${ZEM_MSGS[export_usage]}"
        return 1
    fi

    # Check if profile exists
    if [[ ! -f $profile_file ]]; then
        printf "${ZEM_MSGS[common_not_exist]}\n" "$profile"
        echo "${ZEM_MSGS[common_list_hint]}"
        return 1
    fi

    # Default output file
    if [[ -z $output_file ]]; then
        output_file="$profile.env"
    fi

    # Check if output file already exists
    if [[ -f $output_file ]]; then
        printf "${ZEM_MSGS[export_exists]}\n" "$output_file"
        local prompt="${ZEM_MSGS[export_overwrite]}"
        read "?${prompt}" response
        if [[ ! $response =~ ^[yY]$ ]]; then
            echo "${ZEM_MSGS[common_cancelled]}"
            return 0
        fi
    fi

    # Copy profile to output file
    cp "$profile_file" "$output_file" || {
        printf "${ZEM_MSGS[export_failed]}\n" "$output_file"
        return 1
    }

    printf "${ZEM_MSGS[export_success]}\n" "$profile" "$output_file"
    return 0
}
