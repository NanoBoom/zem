# Show profile content

.zem_show() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local profile=$1
    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local profile_file="$profile_dir/$profile"

    [[ $1 == (-h|--help|help) ]] && { .zem_help show; return $? }

    # Validate arguments
    if [[ -z $profile ]]; then
        echo "${ZEM_MSGS[common_missing_profile]}"
        echo "${ZEM_MSGS[show_usage]}"
        return 1
    fi

    # Check if profile exists
    if [[ ! -f $profile_file ]]; then
        printf "${ZEM_MSGS[common_not_exist]}\n" "$profile"
        echo "${ZEM_MSGS[common_list_hint]}"
        return 1
    fi

    # Display profile header
    printf "${ZEM_MSGS[show_header]}\n" "$profile"
    printf "${ZEM_MSGS[show_location]}\n" "$profile_file"
    echo ""

    # Display content
    cat "$profile_file"

    return 0
}
