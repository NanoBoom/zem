# Add environment variable to profile

.zem_add() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local profile=$1 key=$2 value=$3
    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"

    [[ $1 == (-h|--help|help) ]] && { .zem_help add; return $? }

    # Validate arguments
    if [[ -z $profile ]]; then
        echo "${ZEM_MSGS[common_missing_profile]}"
        echo "${ZEM_MSGS[add_usage]}"
        return 1
    fi

    # Validate profile name
    .zem_validate_profile_name "$profile" || return 1

    if [[ -z $key ]]; then
        echo "${ZEM_MSGS[add_missing_key]}"
        echo "${ZEM_MSGS[add_usage]}"
        return 1
    fi

    if [[ -z $value ]]; then
        echo "${ZEM_MSGS[add_missing_value]}"
        echo "${ZEM_MSGS[add_usage]}"
        return 1
    fi

    # Validate key format (must be valid shell variable name)
    if [[ ! $key =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
        printf "${ZEM_MSGS[add_invalid_key]}\n" "$key"
        echo "${ZEM_MSGS[add_invalid_key_hint]}"
        return 1
    fi

    # Check if profile directory exists
    if [[ ! -d $profile_dir ]]; then
        printf "${ZEM_MSGS[add_no_dir]}\n" "$profile_dir"
        echo "${ZEM_MSGS[add_no_dir_hint]}"
        return 1
    fi

    # Escape special characters in value
    local escaped_value="${value//\\/\\\\}"    # Escape backslashes
    escaped_value="${escaped_value//\"/\\\"}"  # Escape double quotes

    # Append to profile file
    echo "export $key=\"$escaped_value\"" >> "$profile_dir/$profile" || {
        printf "${ZEM_MSGS[add_failed]}\n" "$profile"
        return 1
    }

    printf "${ZEM_MSGS[add_success]}\n" "$key" "$profile"
    return 0
}
