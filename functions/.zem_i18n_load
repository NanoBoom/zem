# Load i18n messages into global associative array ZEM_MSGS

.zem_i18n_load() {
    typeset -gA ZEM_MSGS

    if [[ ${ZEM_LANGUAGE:-en} == zh ]]; then
        ZEM_MSGS=(
            # 通用
            common_missing_profile   "❌ 缺少 profile 名称。"
            common_not_exist         "❌ Profile '%s' 不存在。"
            common_list_hint         "   运行 'zem list' 查看可用 profile。"
            common_cancelled         "已取消。"

            # validate
            validate_invalid         "❌ 无效的 profile 名称：'%s'"
            validate_invalid_slash   "   Profile 名称不能包含 '/' 或 '..'"
            validate_invalid_chars   "   Profile 名称只能包含字母、数字、下划线和连字符。"

            # add
            add_usage               "用法：zem add <profile> <key> <value>"
            add_missing_key         "❌ 缺少变量名。"
            add_missing_value       "❌ 缺少变量值。"
            add_invalid_key         "❌ 无效的变量名：%s"
            add_invalid_key_hint    "变量名必须以字母或下划线开头，且只能包含字母、数字和下划线。"
            add_no_dir              "❌ Profile 目录不存在：%s"
            add_no_dir_hint         "运行 'zem list' 初始化目录。"
            add_failed              "❌ 写入 profile '%s' 失败。"
            add_success             "✅ 已将 %s 添加到 profile '%s'"

            # load
            load_usage              "用法：zem load <profile> [<profile2> ...] [--default]"
            load_warn_exec          "⚠️  警告：将执行来自 '%s' 的代码"
            load_warn_file          "   文件：%s"
            load_confirm            "继续？[y/N] "
            load_success            "🚀 Profile '%s' 加载成功！"
            load_failed             "❌ 加载 profile '%s' 失败。"
            load_failed_default     "❌ 保存默认 profile 失败。"
            load_set_default_single "✅ 已将 '%s' 设为默认 profile。"
            load_set_default_multi  "✅ 已将 '%s' 设为默认 profile。"

            # unload
            unload_usage            "用法：zem unload <profile> [<profile2> ...]"
            unload_success          "🧹 Profile '%s' 已卸载！"

            # list
            list_empty              "📂 未找到任何 profile。"
            list_empty_hint         "使用以下命令创建：zem add <profile> <key> <value>"
            list_header             "📂 可用的 profile："

            # rm
            rm_usage                "用法：zem rm <profile>"
            rm_list_hint            "运行 'zem list' 查看可用 profile。"
            rm_confirm              "⚠️  确定要删除 profile '%s' 吗？"
            rm_confirm_hint         "此操作不可撤销。[y/N] "
            rm_failed               "❌ 删除 profile '%s' 失败。"
            rm_success              "🗑️  Profile '%s' 已成功删除。"

            # edit
            edit_usage              "用法：zem edit <profile>"
            edit_not_exist          "⚠️  Profile '%s' 不存在。"
            edit_create_prompt      "立即创建？[y/N] "
            edit_create_failed      "❌ 创建 profile 文件失败：%s"
            edit_open_failed        "❌ 无法打开编辑器：%s"
            edit_success            "✅ Profile '%s' 已保存。"

            # show
            show_usage              "用法：zem show <profile>"
            show_header             "📄 Profile：%s"
            show_location           "   位置：%s"

            # export
            export_usage            "用法：zem export <profile> [输出文件]"
            export_exists           "⚠️  文件 '%s' 已存在。"
            export_overwrite        "覆盖？[y/N] "
            export_failed           "❌ 导出 profile 到 '%s' 失败。"
            export_success          "📦 Profile '%s' 已导出到：%s"

            # import
            import_usage            "用法：zem import <file> <profile>"
            import_missing_file     "❌ 缺少输入文件。"
            import_not_found        "❌ 文件未找到：%s"
            import_not_text         "⚠️  警告：文件可能不是文本文件：%s"
            import_anyway           "仍然导入？[y/N] "
            import_exists           "⚠️  Profile '%s' 已存在。"
            import_overwrite        "覆盖？[y/N] "
            import_failed           "❌ 导入文件到 profile '%s' 失败。"
            import_success          "📥 文件已导入为 profile '%s'"

            # default
            default_unset_failed    "❌ 取消设置默认 profile 失败。"
            default_unset_success   "✅ 默认 profile 已取消设置。"
            default_unset_hint      "   新 shell 不会自动加载任何 profile。"
            default_none            "📂 未设置默认 profile。"
            default_usage           "用法：zem default <profile> [<profile2> ...]"
            default_current         "📌 默认 profile：%s"
            default_warn_missing    "⚠️  警告：Profile '%s' 不存在。"
            default_set_failed      "❌ 设置默认 profile 失败。"
            default_set_single      "✅ 默认 profile 已设为 '%s'"
            default_set_hint_single "   新 shell 将自动加载此 profile。"
            default_set_multi       "✅ 默认 profile 已设为 '%s'"
            default_set_hint_multi  "   新 shell 将自动加载这些 profile。"

            # current
            current_empty           "📂 当前未加载任何 profile。"
            current_empty_hint      "使用以下命令加载：zem load <profile>"
            current_header          "🔄 已加载的 profile："

            # config
            config_usage            "用法：zem config [get <key>|set <key> <value>]"
            config_unknown_sub      "❌ 未知子命令：%s"
            config_missing_key      "❌ 缺少配置键。"
            config_missing_value    "❌ 缺少配置值。"
            config_invalid_lang     "❌ 无效的 language 值 '%s'。可选值：en zh"
            config_set_success      "✅ 已将 %s 设为 '%s'"
            config_get_unset        "（未设置，默认值：%s）"
            config_header           "📋 当前配置："
            config_lang_reload      "   重新加载 shell 使语言设置生效，或运行：source ~/.zshrc"
        )
    else
        ZEM_MSGS=(
            # Common
            common_missing_profile   "❌ Missing profile name."
            common_not_exist         "❌ Profile '%s' does not exist."
            common_list_hint         "   Run 'zem list' to see available profiles."
            common_cancelled         "Cancelled."

            # validate
            validate_invalid         "❌ Invalid profile name: '%s'"
            validate_invalid_slash   "   Profile names cannot contain '/' or '..'"
            validate_invalid_chars   "   Profile names can only contain letters, numbers, underscores, and hyphens."

            # add
            add_usage               "Usage: zem add <profile> <key> <value>"
            add_missing_key         "❌ Missing variable name."
            add_missing_value       "❌ Missing variable value."
            add_invalid_key         "❌ Invalid variable name: %s"
            add_invalid_key_hint    "Variable names must start with a letter or underscore, and contain only letters, numbers, and underscores."
            add_no_dir              "❌ Profile directory does not exist: %s"
            add_no_dir_hint         "Run 'zem list' to initialize the directory."
            add_failed              "❌ Failed to write to profile: %s"
            add_success             "✅ Added %s to profile '%s'"

            # load
            load_usage              "Usage: zem load <profile> [<profile2> ...] [--default]"
            load_warn_exec          "⚠️  Warning: This will execute code from '%s'"
            load_warn_file          "   File: %s"
            load_confirm            "Continue? [y/N] "
            load_success            "🚀 Profile '%s' loaded successfully!"
            load_failed             "❌ Failed to load profile: %s"
            load_failed_default     "❌ Failed to save default profile(s)."
            load_set_default_single "✅ Set '%s' as default profile."
            load_set_default_multi  "✅ Set '%s' as default profiles."

            # unload
            unload_usage            "Usage: zem unload <profile> [<profile2> ...]"
            unload_success          "🧹 Profile '%s' unloaded successfully!"

            # list
            list_empty              "📂 No profiles found."
            list_empty_hint         "Create one with: zem add <profile> <key> <value>"
            list_header             "📂 Available profiles:"

            # rm
            rm_usage                "Usage: zem rm <profile>"
            rm_list_hint            "Run 'zem list' to see available profiles."
            rm_confirm              "⚠️  Are you sure you want to delete profile '%s'?"
            rm_confirm_hint         "This action cannot be undone. [y/N] "
            rm_failed               "❌ Failed to delete profile: %s"
            rm_success              "🗑️  Profile '%s' deleted successfully."

            # edit
            edit_usage              "Usage: zem edit <profile>"
            edit_not_exist          "⚠️  Profile '%s' does not exist."
            edit_create_prompt      "Create it now? [y/N] "
            edit_create_failed      "❌ Failed to create profile file: %s"
            edit_open_failed        "❌ Failed to open editor: %s"
            edit_success            "✅ Profile '%s' saved."

            # show
            show_usage              "Usage: zem show <profile>"
            show_header             "📄 Profile: %s"
            show_location           "   Location: %s"

            # export
            export_usage            "Usage: zem export <profile> [output-file]"
            export_exists           "⚠️  File '%s' already exists."
            export_overwrite        "Overwrite? [y/N] "
            export_failed           "❌ Failed to export profile to: %s"
            export_success          "📦 Profile '%s' exported to: %s"

            # import
            import_usage            "Usage: zem import <file> <profile>"
            import_missing_file     "❌ Missing input file."
            import_not_found        "❌ File not found: %s"
            import_not_text         "⚠️  Warning: File may not be a text file: %s"
            import_anyway           "Import anyway? [y/N] "
            import_exists           "⚠️  Profile '%s' already exists."
            import_overwrite        "Overwrite? [y/N] "
            import_failed           "❌ Failed to import file to profile: %s"
            import_success          "📥 File imported as profile '%s'"

            # default
            default_unset_failed    "❌ Failed to unset default profile."
            default_unset_success   "✅ Default profile unset."
            default_unset_hint      "   New shells will not auto-load any profile."
            default_none            "📂 No default profile set."
            default_usage           "Usage: zem default <profile> [<profile2> ...]"
            default_current         "📌 Default profile(s): %s"
            default_warn_missing    "⚠️  Warning: Profile '%s' does not exist."
            default_set_failed      "❌ Failed to set default profile."
            default_set_single      "✅ Default profile set to '%s'"
            default_set_hint_single "   New shells will automatically load this profile."
            default_set_multi       "✅ Default profiles set to '%s'"
            default_set_hint_multi  "   New shells will automatically load these profiles."

            # current
            current_empty           "📂 No profiles loaded."
            current_empty_hint      "Load one with: zem load <profile>"
            current_header          "🔄 Loaded profiles:"

            # config
            config_usage            "Usage: zem config [get <key>|set <key> <value>]"
            config_unknown_sub      "❌ Unknown subcommand: %s"
            config_missing_key      "❌ Missing config key."
            config_missing_value    "❌ Missing config value."
            config_invalid_lang     "❌ Invalid language '%s'. Valid values: en zh"
            config_set_success      "✅ Set %s to '%s'"
            config_get_unset        "(not set, default: %s)"
            config_header           "📋 Current configuration:"
            config_lang_reload      "   Reload your shell or run: source ~/.zshrc"
        )
    fi
}
