# Edit profile with $EDITOR

.zem_edit() {
    emulate -L zsh
    setopt extended_glob warn_create_global typeset_silent

    local MATCH REPLY
    integer MBEGIN MEND
    local -a match mbegin mend reply

    local profile=$1
    local profile_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zem/profiles"
    local profile_file="$profile_dir/$profile"

    [[ $1 == (-h|--help|help) ]] && { .zem_help edit; return $? }

    # Validate arguments
    if [[ -z $profile ]]; then
        echo "${ZEM_MSGS[common_missing_profile]}"
        echo "${ZEM_MSGS[edit_usage]}"
        return 1
    fi

    # Check if profile exists
    if [[ ! -f $profile_file ]]; then
        printf "${ZEM_MSGS[edit_not_exist]}\n" "$profile"
        local prompt="${ZEM_MSGS[edit_create_prompt]}"
        read "?${prompt}" response
        if [[ ! $response =~ ^[yY]$ ]]; then
            echo "${ZEM_MSGS[common_cancelled]}"
            return 0
        fi
        # Create empty profile with header
        {
            cat > "$profile_file" <<'EOF'
# Environment profile: $profile
# Add your environment variables below in the format:
# export VAR_NAME="value"

EOF
        } || {
            printf "${ZEM_MSGS[edit_create_failed]}\n" "$profile_file"
            return 1
        }
    fi

    # Determine editor
    local editor="${EDITOR:-vi}"

    # Open editor
    "$editor" "$profile_file" || {
        printf "${ZEM_MSGS[edit_open_failed]}\n" "$editor"
        return 1
    }

    printf "${ZEM_MSGS[edit_success]}\n" "$profile"
    return 0
}
